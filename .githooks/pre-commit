#!/usr/bin/env bash
# AICAM Pre-commit Hook — v1.3.0
#
# Installed via: ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
# Or via husky: npx husky add .husky/pre-commit
#
# Lightweight checks (< 30s) that run before every commit.
# Full gates run in CI via .github/workflows/aicam-gates.yml.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

FAIL=0

echo -e "${GREEN}── AICAM Pre-commit ──${NC}"

# 1. Spec-Lite existence check ───────────────────────────────────
echo "  Checking Spec-Lite coverage..."

PLAN_DIR=".agents/plans"
SPEC_DIR=".agents/specs"

if [ -d "$PLAN_DIR" ]; then
  PLAN_COUNT=$(find "$PLAN_DIR" -maxdepth 1 -name "*.md" ! -name "*.summary.md" 2>/dev/null | wc -l | tr -d ' ')
  SPEC_COUNT=$(find "$SPEC_DIR" -name "*.spec.md" 2>/dev/null | wc -l | tr -d ' ')

  if [ "${PLAN_COUNT:-0}" -gt "${SPEC_COUNT:-0}" ]; then
    echo -e "  ${YELLOW}⚠  Plan files ($PLAN_COUNT) > Spec-Lite files ($SPEC_COUNT)${NC}"
    echo "     Each plan must have a corresponding Spec-Lite."
    echo "     Run /plan-feature to generate missing Spec-Lite."
    FAIL=1
  else
    echo "  ✅ Spec-Lite: $SPEC_COUNT files"
  fi
fi

# 2. CLAUDE.md size check ───────────────────────────────────────
echo "  Checking CLAUDE.md health..."

if [ -f "CLAUDE.md" ]; then
  CLAUDE_LINES=$(wc -l < CLAUDE.md | tr -d ' ')
  if [ "$CLAUDE_LINES" -gt 150 ]; then
    echo -e "  ${YELLOW}⚠  CLAUDE.md is $CLAUDE_LINES lines (> 150 threshold)${NC}"
    echo "     Consider running /close-phase to compress iteration log."
  else
    echo "  ✅ CLAUDE.md: $CLAUDE_LINES lines"
  fi
fi

# 3. Secrets detection (gitleaks, if available) ──────────────────
echo "  Checking secrets..."

if command -v gitleaks &> /dev/null; then
  if gitleaks detect --source . --no-git --verbose 2>/dev/null; then
    echo "  ✅ Secrets: clean"
  else
    echo -e "  ${RED}❌ Secrets detected by gitleaks!${NC}"
    FAIL=1
  fi
else
  echo "  ⏭  gitleaks not installed — skipping (run: brew install gitleaks)"
fi

# 4. Large file warning ──────────────────────────────────────────
echo "  Checking file sizes..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
LARGE_FILES=""
for f in $STAGED_FILES; do
  if [ -f "$f" ]; then
    SIZE=$(wc -c < "$f" | tr -d ' ')
    if [ "$SIZE" -gt 500000 ]; then  # > 500KB
      LARGE_FILES="$LARGE_FILES  $f ($(echo "scale=1; $SIZE/1024" | bc)KB)\n"
    fi
  fi
done

if [ -n "$LARGE_FILES" ]; then
  echo -e "  ${YELLOW}⚠  Large files staged:${NC}"
  echo -e "$LARGE_FILES"
  echo "     Consider if these belong in the repo or should be .gitignored."
fi

# ── Result ─────────────────────────────────────────────────────
echo ""
echo "  Config files present:"
[ -f ".commitlintrc.yaml" ] && echo "    ✅ .commitlintrc.yaml (commit-msg hook available)"
echo ""
if [ "$FAIL" -eq 0 ]; then
  echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
  exit 0
else
  echo -e "${RED}❌ Pre-commit checks failed — see details above${NC}"
  echo "  (use git commit --no-verify to bypass, but CI will still run these)"
  exit 1
fi
